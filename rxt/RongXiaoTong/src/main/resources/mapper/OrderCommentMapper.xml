<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qst.crop.dao.OrderCommentDao">
    <resultMap id="BaseResultMap" type="com.qst.crop.entity.OrderComment">
        <id column="comment_id" jdbcType="INTEGER" property="commentId" />
        <result column="purchase_id" jdbcType="INTEGER" property="purchaseId" />
        <result column="order_id" jdbcType="INTEGER" property="orderId" />
        <result column="buyer_name" jdbcType="VARCHAR" property="buyerName" />
        <result column="seller_name" jdbcType="VARCHAR" property="sellerName" />
        <result column="rating" jdbcType="INTEGER" property="rating" />
        <result column="content" jdbcType="VARCHAR" property="content" />
        <result column="create_time" jdbcType="TIMESTAMP" property="createTime" />
    </resultMap>

    <sql id="Base_Column_List">
        comment_id, purchase_id, order_id, buyer_name, seller_name, rating, content, create_time
    </sql>

    <insert id="insert" parameterType="com.qst.crop.entity.OrderComment">
        insert into tb_order_comment (purchase_id, order_id, buyer_name, seller_name, rating, content, create_time)
        values (#{purchaseId,jdbcType=INTEGER}, #{orderId,jdbcType=INTEGER}, #{buyerName,jdbcType=VARCHAR},
                #{sellerName,jdbcType=VARCHAR}, #{rating,jdbcType=INTEGER}, #{content,jdbcType=VARCHAR}, #{createTime,jdbcType=TIMESTAMP})
    </insert>

    <select id="selectByPurchaseId" parameterType="java.lang.Integer" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List" />
        from tb_order_comment
        where purchase_id = #{purchaseId,jdbcType=INTEGER}
    </select>

    <select id="selectByOrderId" parameterType="java.lang.Integer" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List" />
        from tb_order_comment
        where order_id = #{orderId,jdbcType=INTEGER}
    </select>

    <select id="selectBySellerName" parameterType="java.lang.String" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List" />
        from tb_order_comment
        where seller_name = #{sellerName,jdbcType=VARCHAR}
        order by create_time desc
    </select>

    <select id="selectAvgRatingBySellerName" parameterType="java.lang.String" resultType="java.lang.Double">
        select avg(rating) from tb_order_comment
        where seller_name = #{sellerName,jdbcType=VARCHAR}
    </select>
</mapper>